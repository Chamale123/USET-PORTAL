rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "chamlamin693@gmail.com" && request.auth.token.email_verified == true));
    }

    function isLecturer() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'lecturer';
    }

    function isStudent() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'name', 'role', 'studentId', 'department', 'level', 'phone', 'photoUrl', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role in ['applicant', 'student', 'lecturer', 'admin'] &&
             (!('studentId' in data) || (data.studentId is string && data.studentId.size() < 50)) &&
             (!('department' in data) || (data.department is string && data.department.size() < 100)) &&
             (!('level' in data) || (data.level is number && data.level > 0)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() < 50)) &&
             (!('photoUrl' in data) || (data.photoUrl is string && data.photoUrl.size() < 1048576)) &&
             data.createdAt is timestamp;
    }

    function isValidApplication(data) {
      return hasOnlyAllowedFields(['userId', 'program', 'status', 'previousSchool', 'grades', 'phoneNumber', 'dateOfBirth', 'address', 'qualification', 'gender', 'nationality', 'guardianName', 'guardianPhone', 'yearOfCompletion', 'passportPhoto', 'transcriptFile', 'birthCertificateFile', 'academicCertificateFile', 'createdAt']) &&
             data.userId is string &&
             data.program is string && data.program.size() > 0 && data.program.size() < 100 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             (!('previousSchool' in data) || (data.previousSchool is string && data.previousSchool.size() < 200)) &&
             (!('grades' in data) || (data.grades is string && data.grades.size() < 1000)) &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() < 50)) &&
             (!('dateOfBirth' in data) || (data.dateOfBirth is string && data.dateOfBirth.size() < 50)) &&
             (!('address' in data) || (data.address is string && data.address.size() < 500)) &&
             (!('qualification' in data) || (data.qualification in ['WASSCE', 'Diploma', 'HND', 'Degree', 'Other'])) &&
             (!('gender' in data) || (data.gender in ['Male', 'Female', 'Other'])) &&
             (!('nationality' in data) || (data.nationality is string && data.nationality.size() < 100)) &&
             (!('guardianName' in data) || (data.guardianName is string && data.guardianName.size() < 100)) &&
             (!('guardianPhone' in data) || (data.guardianPhone is string && data.guardianPhone.size() < 50)) &&
             (!('yearOfCompletion' in data) || (data.yearOfCompletion is string && data.yearOfCompletion.size() < 10)) &&
             (!('passportPhoto' in data) || (data.passportPhoto is string && data.passportPhoto.size() < 500)) &&
             (!('transcriptFile' in data) || (data.transcriptFile is string && data.transcriptFile.size() < 500)) &&
             (!('birthCertificateFile' in data) || (data.birthCertificateFile is string && data.birthCertificateFile.size() < 500)) &&
             (!('academicCertificateFile' in data) || (data.academicCertificateFile is string && data.academicCertificateFile.size() < 500)) &&
             data.createdAt is timestamp;
    }

    function isValidCourse(data) {
      return hasOnlyAllowedFields(['courseCode', 'title', 'credits', 'lecturerId', 'department']) &&
             data.courseCode is string && data.courseCode.size() > 0 && data.courseCode.size() < 20 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.credits is number && data.credits > 0 && data.credits <= 10 &&
             (!('lecturerId' in data) || (data.lecturerId is string)) &&
             data.department is string && data.department.size() > 0 && data.department.size() < 100;
    }

    function isValidRegistration(data) {
      return hasOnlyAllowedFields(['studentId', 'courseId', 'semester', 'status', 'createdAt']) &&
             data.studentId is string &&
             data.courseId is string &&
             data.semester is string && data.semester.size() > 0 && data.semester.size() < 50 &&
             data.status in ['registered', 'dropped', 'completed'] &&
             data.createdAt is timestamp;
    }

    function isValidResult(data) {
      return hasOnlyAllowedFields(['studentId', 'courseId', 'courseCode', 'grade', 'score', 'semester', 'createdAt']) &&
             data.studentId is string &&
             data.courseId is string &&
             data.courseCode is string && data.courseCode.size() > 0 && data.courseCode.size() < 20 &&
             data.grade is string && data.grade.size() > 0 && data.grade.size() < 5 &&
             data.score is number && data.score >= 0 && data.score <= 100 &&
             data.semester is string && data.semester.size() > 0 && data.semester.size() < 50 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /{document=**} {
      allow read, write: if true;
    }
  }
}